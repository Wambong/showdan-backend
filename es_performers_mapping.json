{
  "settings": {
    "number_of_shards": 1,
    "number_of_replicas": 0,
    "analysis": {
      "analyzer": {
        "performer_analyzer": {
          "type": "custom",
          "tokenizer": "standard",
          "filter": [
            "lowercase",
            "russian_morphology",
            "english_morphology"
          ]
        },
        "autocomplete": {
          "tokenizer": "autocomplete_tokenizer",
          "filter": [
            "lowercase"
          ]
        }
      },
      "tokenizer": {
        "autocomplete_tokenizer": {
          "type": "edge_ngram",
          "min_gram": 2,
          "max_gram": 20,
          "token_chars": [
            "letter",
            "digit"
          ]
        }
      },
      "filter": {
        "russian_morphology": {
          "type": "snowball",
          "language": "Russian"
        },
        "english_morphology": {
          "type": "snowball",
          "language": "English"
        }
      }
    }
  },
  "mappings": {
    "properties": {
      "id": {
        "type": "keyword"
      },
      "type": {
        "type": "keyword"
      },
      "first_name": {
        "type": "text",
        "analyzer": "performer_analyzer"
      },
      "last_name": {
        "type": "text",
        "analyzer": "performer_analyzer"
      },
      "stage_name": {
        "type": "text",
        "analyzer": "performer_analyzer",
        "fields": {
          "suggest": {
            "type": "text",
            "analyzer": "autocomplete",
            "search_analyzer": "standard"
          }
        }
      },
      "photo_url": {
        "type": "keyword",
        "index": false
      },
      "about": {
        "type": "text",
        "analyzer": "performer_analyzer"
      },
      "description": {
        "type": "text",
        "analyzer": "performer_analyzer"
      },
      "birth_date": {
        "type": "date"
      },
      "experience_years": {
        "type": "integer"
      },
      "xp_points": {
        "type": "integer"
      },
      "current_level": {
        "type": "integer"
      },
      "hourly_rate": {
        "type": "scaled_float",
        "scaling_factor": 100
      },
      "rating": {
        "type": "float"
      },
      "current_city_name": {
        "type": "keyword"
      },
      "location_point": {
        "type": "geo_point"
      },
      "comm_language_ids": {
        "type": "integer"
      },
      "perf_language_ids": {
        "type": "integer"
      },
      "genre_ids": {
        "type": "integer"
      },
      "event_category_ids": {
        "type": "integer"
      },
      "specific_attributes": {
        "type": "object",
        "dynamic": true
      },
      "created_at": {
        "type": "date"
      }
    }
  }
}